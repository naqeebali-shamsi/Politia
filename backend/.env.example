# Database (Neon PostgreSQL)
POLITIA_DATABASE_URL=postgresql+psycopg2://user:password@ep-xxx.us-east-2.aws.neon.tech/politia?sslmode=require

# For local development with SQLite (no PostgreSQL needed)
# POLITIA_DATABASE_URL=sqlite:///./politia.db

# CORS
POLITIA_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Debug
POLITIA_DEBUG=true
POLITIA_DATABASE_ECHO=false

# Cloudflare R2 (optional, for raw artifact storage)
POLITIA_STORAGE_ENDPOINT=
POLITIA_STORAGE_ACCESS_KEY=
POLITIA_STORAGE_SECRET_KEY=
POLITIA_STORAGE_BUCKET=politia-raw
